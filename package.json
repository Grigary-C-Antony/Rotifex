{
  "name": "rotifex",
  "version": "0.1.7",
  "description": "Rotifex — a modern CLI toolkit for project scaffolding, development, and migrations.",
  "type": "module",
  "bin": {
    "rotifex": "./bin/rotifex.js"
  },
  "files": [
    "bin",
    "src",
    "admin/dist",
    "config.default.json"
  ],
  "scripts": {
    "start": "node bin/rotifex.js start",
    "dev": "node bin/rotifex.js start --verbose",
    "build:admin": "cd admin && npx vite build",
    "dev:admin": "cd admin && npx vite",
    "prepublishOnly": "npm run build:admin",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "keywords": [
    "rotifex",
    "backend-as-a-service",
    "baas",
    "self-hosted-backend",
    "api-generator",
    "rest-api-generator",
    "dynamic-api",
    "schema-driven-api",
    "fastify",
    "nodejs-backend",
    "low-code-backend",
    "no-code-backend",
    "sqlite-backend",
    "admin-dashboard",
    "jwt-authentication",
    "file-storage",
    "ai-platform",
    "llm-platform",
    "ai-agents",
    "developer-tools",
    "supabase-alternative",
    "firebase-alternative",
    "backend-framework"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fastify": "^5.7.4",
    "jsonwebtoken": "^9.0.3",
    "pino-pretty": "^13.1.3",
    "sequelize": "^6.37.8",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "mysql2": "^3.19.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4"
  }
}
