{
  "User": {
    "fields": {
      "email": {
        "type": "string",
        "required": true,
        "unique": true
      },
      "display_name": {
        "type": "string"
      },
      "role": {
        "type": "string",
        "default": "user"
      }
    }
  },
  "Product": {
    "fields": {
      "name": "string",
      "price": "number",
      "in_stock": "boolean"
    }
  }
}